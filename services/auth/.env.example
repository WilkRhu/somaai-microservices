# Application
NODE_ENV=development
APP_NAME=somaai-auth-service
APP_PORT=3000
APP_DEBUG=true

# Database
DB_HOST=mysql-master
DB_PORT=3306
DB_USERNAME=somaai
DB_PASSWORD=somaai_password
DB_DATABASE=somaai_auth
DB_SYNCHRONIZE=true
DB_LOGGING=true

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=3600
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRATION=604800

# Bcrypt
BCRYPT_ROUNDS=10

# Kafka
KAFKA_BROKERS=kafka-1:29092,kafka-2:29092,kafka-3:29092
KAFKA_CLIENT_ID=auth-service
KAFKA_GROUP_ID=auth-service-group

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Logging
LOG_LEVEL=debug
