# Application
NODE_ENV=development
APP_NAME=somaai-ocr-service
APP_PORT=3006
APP_DEBUG=true

# Database
DB_HOST=mysql-master
DB_PORT=3306
DB_USERNAME=somaai
DB_PASSWORD=somaai_password
DB_DATABASE=somaai_ocr
DB_SYNCHRONIZE=true
DB_LOGGING=true

# Kafka
KAFKA_BROKERS=kafka-1:29092,kafka-2:29092,kafka-3:29092
KAFKA_CLIENT_ID=ocr-service
KAFKA_GROUP_ID=ocr-service-group

# OCR
OCR_LANGUAGE=por
OCR_CONFIDENCE_THRESHOLD=0.5

# Logging
LOG_LEVEL=debug
