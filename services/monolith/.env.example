# Application
NODE_ENV=development
APP_NAME=somaai-monolith-service
APP_PORT=3000
APP_DEBUG=true

# Database
DB_HOST=mysql-master
DB_PORT=3306
DB_USERNAME=somaai
DB_PASSWORD=somaai_password
DB_DATABASE=somaai_monolith
DB_SYNCHRONIZE=true
DB_LOGGING=true

# Auth Service
AUTH_SERVICE_URL=http://auth:3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=3600

# Kafka
KAFKA_BROKERS=kafka-1:29092,kafka-2:29092,kafka-3:29092
KAFKA_CLIENT_ID=monolith-service
KAFKA_GROUP_ID=monolith-service-group

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Logging
LOG_LEVEL=debug
